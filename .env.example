# AI4K8s Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to git (it's in .gitignore)

# Flask Configuration
# Generate a strong secret key with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-hex-32

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5003

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///instance/ai4k8s.db

# Admin User Configuration (REQUIRED - no defaults for security)
# Set a strong password (at least 12 characters, mix of upper/lower/numbers/special)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your-strong-password-here
DEFAULT_ADMIN_EMAIL=admin@local

# GPT OSS Configuration (for local LLM server)
GPT_OSS_API_BASE=http://localhost:8001/v1
GPT_OSS_API_KEY=not-needed

# Groq API (optional fallback if GPT OSS unavailable)
# Get free API key from https://console.groq.com
GROQ_API_KEY=

# Anthropic API (optional fallback)
# ANTHROPIC_API_KEY=

# MCDA decision profile — controls the TOPSIS criteria weights used by Ai4k8s.
# Available profiles (defined in mcda_optimizer.py:WEIGHT_PROFILES):
#   balanced           cost=0.15  perf=0.30  stab=0.25  forecast=0.25  resp=0.05  (default)
#   performance_first  cost=0.10  perf=0.40  stab=0.15  forecast=0.20  resp=0.15
#   cost_optimized     cost=0.40  perf=0.20  stab=0.20  forecast=0.15  resp=0.05
# Higher `perf` weight makes MCDA agree with the LLM's scale-up calls more often,
# trading a slight cost increase for fewer SLA violations under burst load.
MCDA_PROFILE=balanced

# How big the MCDA score gap must be before MCDA overrides the LLM. Lower values
# make MCDA more deferential to the LLM. Default 0.15.
# MCDA_AGREEMENT_THRESHOLD=0.15
