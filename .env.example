# AI4K8s Environment Variables
# Copy this file to .env and fill in the values
# DO NOT commit .env to git (it's in .gitignore)

# Flask Configuration
# Generate a strong secret key with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-hex-32

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5003

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///instance/ai4k8s.db

# Admin User Configuration (REQUIRED - no defaults for security)
# Set a strong password (at least 12 characters, mix of upper/lower/numbers/special)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your-strong-password-here
DEFAULT_ADMIN_EMAIL=admin@local

# GPT OSS Configuration (for local LLM server)
GPT_OSS_API_BASE=http://localhost:8001/v1
GPT_OSS_API_KEY=not-needed

# Groq API (optional fallback if GPT OSS unavailable)
# Get free API key from https://console.groq.com
GROQ_API_KEY=

# Anthropic API (optional fallback)
# ANTHROPIC_API_KEY=

# MCDA decision profile — controls the TOPSIS criteria weights used by Ai4k8s.
# Available profiles (defined in mcda_optimizer.py:WEIGHT_PROFILES):
#   balanced           cost=0.15  perf=0.30  stab=0.25  forecast=0.25  resp=0.05  (default)
#   performance_first  cost=0.10  perf=0.40  stab=0.15  forecast=0.20  resp=0.15
#   cost_optimized     cost=0.40  perf=0.20  stab=0.20  forecast=0.15  resp=0.05
# Higher `perf` weight makes MCDA agree with the LLM's scale-up calls more often,
# trading a slight cost increase for fewer SLA violations under burst load.
MCDA_PROFILE=balanced

# How big the MCDA score gap must be before MCDA overrides the LLM. **Higher**
# values make MCDA more deferential to the LLM (it needs a bigger gap to override).
# Default 0.15. Empirically, raising to 0.20 lets ~half of the borderline gaps
# (around 0.18) through, which is what produces a real Ai4k8s SLA improvement
# under burst load. See thesis_reports/EASY_EXPLAINER.md for the data behind this.
MCDA_AGREEMENT_THRESHOLD=0.20

# Cost criterion compression exponent (Phase H, Knob 2). Default 1.0 (linear).
# Set to 0.5 for sqrt compression: cost values for [2,3,4] replicas at max=4
# go from [0.50, 0.75, 1.00] to [0.71, 0.87, 1.00], shrinking the cost
# differential between adjacent actions so Performance/Forecast carry more
# weight in TOPSIS distances.
MCDA_COST_EXPONENT=1.0

# Burst-override safety net (Phase H, Knob 3). When enabled, the advisor
# bypasses MCDA validation entirely if measured CPU exceeds the threshold AND
# there is replica headroom (current_replicas < max_replicas). The override
# adds +1 replica per tick — it does not jump to max — and stops at maxReplicas.
# Default off so baseline Ai4k8s behaviour is preserved for paper comparisons.
BURST_OVERRIDE_ENABLED=0
BURST_OVERRIDE_CPU_PCT=60
