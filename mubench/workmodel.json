{
  "ingest": {
    "external_services": [
      {
        "seq_len": 100,
        "services": ["process"]
      }
    ],
    "internal_service": {
      "image_processing": {
        "width":      640,
        "height":     480,
        "iterations": 6
      }
    },
    "request_method": "rest",
    "workers":   2,
    "threads":   4,
    "url":       "ingest.default.svc.cluster.local:8080",
    "path":      "/api/v1",
    "image":     "msvcbench/microservice:latest",
    "namespace": "default"
  },

  "process": {
    "external_services": [
      {
        "seq_len": 100,
        "services": ["analyze"]
      }
    ],
    "internal_service": {
      "matrix_compute": {
        "input_size":  1024,
        "hidden_size": 512,
        "num_layers":  6,
        "num_classes": 80,
        "batch_size":  16
      }
    },
    "request_method": "rest",
    "workers":   2,
    "threads":   4,
    "url":       "process.default.svc.cluster.local:8080",
    "path":      "/api/v1",
    "image":     "msvcbench/microservice:latest",
    "namespace": "default"
  },

  "analyze": {
    "external_services": [
      {
        "seq_len": 100,
        "services": []
      }
    ],
    "internal_service": {
      "video_frames": {
        "num_frames":       32,
        "frame_width":      640,
        "frame_height":     480,
        "motion_threshold": 25.0
      }
    },
    "request_method": "rest",
    "workers":   2,
    "threads":   4,
    "url":       "analyze.default.svc.cluster.local:8080",
    "path":      "/api/v1",
    "image":     "msvcbench/microservice:latest",
    "namespace": "default"
  }
}
